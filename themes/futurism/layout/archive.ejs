<div class="archive container">
  <h1 class="archive__title">归档</h1>
  <p class="archive__count">共 <%= site.posts.length %> 篇文章</p>

  <%
    var postsByYear = {};
    site.posts.sort('date', -1).forEach(function(post) {
      var year = date(post.date, 'YYYY');
      if (!postsByYear[year]) postsByYear[year] = [];
      postsByYear[year].push(post);
    });
    var years = Object.keys(postsByYear).sort().reverse();
  %>

  <% years.forEach(function(year) { %>
  <section class="archive-year">
    <h2 class="archive-year__title"><%= year %></h2>
    <ul class="archive-year__list">
      <% postsByYear[year].forEach(function(post) { %>
      <li class="archive-item">
        <time class="archive-item__date" datetime="<%= date(post.date, 'YYYY-MM-DD') %>">
          <%= date(post.date, 'MM-DD') %>
        </time>
        <a href="<%- url_for(post.path) %>" class="archive-item__title"><%= post.title %></a>
        <% if (post.categories && post.categories.length) { %>
          <span class="archive-item__cat">
            <% post.categories.forEach(function(cat) { %>
              <a href="<%- url_for(cat.path) %>"><%= cat.name %></a>
            <% }) %>
          </span>
        <% } %>
      </li>
      <% }) %>
    </ul>
  </section>
  <% }) %>
</div>
