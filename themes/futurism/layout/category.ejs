<div class="taxonomy container">
  <h1 class="taxonomy__title">
    <span class="taxonomy__icon">📂</span> 分类：<%= page.category %>
  </h1>
  <p class="taxonomy__count">共 <%= page.posts.length %> 篇</p>

  <div class="post-grid">
    <% page.posts.sort('date', -1).forEach(function(post) { %>
      <%- partial('_partial/post-card', { post: post }) %>
    <% }) %>
  </div>

  <!-- 所有分类 -->
  <section class="taxonomy-all">
    <h2 class="section-title">所有分类</h2>
    <div class="tag-cloud">
      <% site.categories.sort('name').forEach(function(cat) { %>
        <a href="<%- url_for(cat.path) %>"
           class="tag-chip <%= cat.name === page.category ? 'tag-chip--active' : '' %>">
          <%= cat.name %> <span class="tag-count"><%= cat.length %></span>
        </a>
      <% }) %>
    </div>
  </section>
</div>
