<article class="post container">

  <!-- 阅读进度条 -->
  <% if (theme.post.toc) { %>
  <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>
  <% } %>

  <div class="post-layout">

    <!-- TOC 侧边栏 -->
    <% if (theme.post.toc && toc(page.content).length > 0) { %>
    <aside class="toc-sidebar" id="tocSidebar" aria-label="文章目录">
      <div class="toc-title">目录</div>
      <%- toc(page.content, { list_number: false, max_depth: theme.post.toc_depth || 3 }) %>
    </aside>
    <% } %>

    <!-- 文章主体 -->
    <div class="post-body">

      <!-- 文章头部 -->
      <header class="post-header">
        <h1 class="post-header__title"><%= page.title %></h1>

        <div class="post-header__meta">
          <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>">
            📅 发布于 <%= date(page.date, 'YYYY-MM-DD') %>
          </time>
          <% if (page.updated && page.updated !== page.date) { %>
          <time datetime="<%= date(page.updated, 'YYYY-MM-DD') %>">
            · 更新于 <%= date(page.updated, 'YYYY-MM-DD') %>
          </time>
          <% } %>
          <% if (theme.post.word_count) { %>
          <span>📝 <%= wordcount(page.content) %> 字</span>
          <% } %>
          <% if (theme.post.reading_time) { %>
          <span>⏱ <%= min2read(page.content) %> 分钟阅读</span>
          <% } %>
        </div>

        <% if (page.categories && page.categories.length) { %>
        <div class="post-header__categories">
          <% page.categories.forEach(function(cat) { %>
            <a href="<%- url_for(cat.path) %>" class="post-category-chip"><%= cat.name %></a>
          <% }) %>
        </div>
        <% } %>

        <% if (page.cover) { %>
        <div class="post-header__cover">
          <img src="<%- url_for(page.cover) %>" alt="<%= page.title %>" loading="lazy">
        </div>
        <% } %>
      </header>

      <!-- 文章正文 -->
      <div class="post-content prose" id="post-content">
        <%- page.content %>
      </div>

      <!-- 文章标签 -->
      <% if (page.tags && page.tags.length) { %>
      <div class="post-tags">
        <% page.tags.forEach(function(tag) { %>
          <a href="<%- url_for(tag.path) %>" class="tag-chip">#<%= tag.name %></a>
        <% }) %>
      </div>
      <% } %>

      <!-- 版权声明 -->
      <% if (theme.post.copyright && theme.post.copyright.enable) { %>
      <div class="post-copyright">
        <p>
          © <%= theme.post.copyright.author %> ·
          <a href="<%= theme.post.copyright.link %>"><%= theme.post.copyright.link %></a>
          <br>
          原创内容，转载请注明出处。
        </p>
      </div>
      <% } %>

      <!-- 上一篇 / 下一篇 -->
      <% if (theme.post_pagination) { %>
      <nav class="post-nav" aria-label="文章导航">
        <% if (page.prev) { %>
        <a href="<%- url_for(page.prev.path) %>" class="post-nav__item post-nav__prev">
          <span class="post-nav__label">← 上一篇</span>
          <span class="post-nav__title"><%= page.prev.title %></span>
        </a>
        <% } %>
        <% if (page.next) { %>
        <a href="<%- url_for(page.next.path) %>" class="post-nav__item post-nav__next">
          <span class="post-nav__label">下一篇 →</span>
          <span class="post-nav__title"><%= page.next.title %></span>
        </a>
        <% } %>
      </nav>
      <% } %>

      <!-- 评论区 -->
      <% if (theme.comments.enable && theme.comments.provider === 'giscus') { %>
      <div id="comments" class="post-comments">
        <script src="https://giscus.app/client.js"
          data-repo="<%= theme.giscus.repo %>"
          data-repo-id="<%= theme.giscus.repo_id %>"
          data-category="<%= theme.giscus.category %>"
          data-category-id="<%= theme.giscus.category_id %>"
          data-mapping="<%= theme.giscus.mapping %>"
          data-reactions-enabled="<%= theme.giscus.reactions_enabled %>"
          data-emit-metadata="<%= theme.giscus.emit_metadata %>"
          data-theme="<%= theme.giscus.theme %>"
          data-lang="<%= theme.giscus.lang %>"
          crossorigin="anonymous"
          async>
        </script>
      </div>
      <% } %>

    </div>
  </div>
</article>
