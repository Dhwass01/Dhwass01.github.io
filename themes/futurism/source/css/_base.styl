// ============================================
//  Base Reset + Global Styles
// ============================================

// ----- Box Sizing -----
*, *::before, *::after
  box-sizing border-box
  margin 0
  padding 0

// ----- Document -----
html
  font-size 16px
  scroll-behavior smooth
  -webkit-text-size-adjust 100%
  text-size-adjust 100%

// ----- Body -----
body
  font-family $font-body
  font-size $text-base
  line-height 1.7
  color var(--text-primary)
  background var(--bg-base)
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  transition background $transition-slow, color $transition-slow
  overflow-x hidden
  min-height 100vh

// ----- Selection -----
::selection
  background rgba(124, 92, 255, 0.30)
  color var(--text-primary)

// ----- 滚动条 (Webkit) -----
::-webkit-scrollbar
  width 8px
  height 8px

::-webkit-scrollbar-track
  background var(--scrollbar-track)

::-webkit-scrollbar-thumb
  background var(--scrollbar-thumb)
  border-radius 4px

::-webkit-scrollbar-thumb:hover
  background var(--brand-primary)

// ----- 链接 -----
a
  color var(--brand-accent)
  text-decoration none
  transition color $transition-fast, box-shadow $transition-fast

  &:hover
    color var(--brand-primary)
    text-shadow 0 0 8px rgba(0, 229, 255, 0.4)

  &:focus-visible
    outline 2px solid var(--brand-primary)
    outline-offset 2px
    border-radius $radius-sm

// ----- 图片 -----
img
  max-width 100%
  height auto
  display block

// ----- 列表 -----
ul, ol
  padding-left 1.5em

// ----- 按钮重置 -----
button
  font inherit
  color inherit
  background none
  border none
  cursor pointer
  outline none

  &:focus-visible
    outline 2px solid var(--brand-primary)
    outline-offset 2px
    border-radius $radius-sm

// ----- 容器 -----
.container
  width 100%
  max-width $container-max-width
  margin 0 auto
  padding 0 $space-lg

// ----- 主内容区 -----
.site-main
  min-height calc(100vh - 160px)
  padding-top 64px  // 为固定 header 留空间

// ----- 辅助类 -----
.sr-only
  position absolute
  width 1px
  height 1px
  padding 0
  margin -1px
  overflow hidden
  clip rect(0, 0, 0, 0)
  white-space nowrap
  border 0

.text-gradient
  background linear-gradient(135deg, var(--brand-primary), var(--brand-accent))
  -webkit-background-clip text
  background-clip text
  -webkit-text-fill-color transparent

.glow-box
  box-shadow var(--glow-primary)
  transition box-shadow $transition-base

  &:hover
    box-shadow 0 0 32px rgba(124, 92, 255, 0.50)
