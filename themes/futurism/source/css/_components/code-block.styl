// ============================================
//  Code Block — Prism 代码块增强
// ============================================

// 代码块容器
.code-block-wrapper
  position relative
  margin 1.5em 0

  &:hover .code-copy-btn
    opacity 1

// 文件名标签
.code-filename
  display inline-block
  font-family $font-mono
  font-size $text-xs
  color var(--text-muted)
  background var(--bg-overlay)
  padding 0.3em 0.8em
  border-radius $radius-sm $radius-sm 0 0
  border 1px solid var(--border-subtle)
  border-bottom none
  position relative
  top 1px

// 复制按钮
.code-copy-btn
  position absolute
  top $space-sm
  right $space-sm
  display flex
  align-items center
  gap 4px
  padding 0.3em 0.6em
  font-family $font-mono
  font-size $text-xs
  color var(--text-muted)
  background var(--bg-elevated)
  border 1px solid var(--border-subtle)
  border-radius $radius-sm
  opacity 0
  transition opacity $transition-fast, color $transition-fast, background $transition-fast
  z-index 2

  &:hover
    color var(--text-primary)
    background var(--bg-overlay)

  &.copied
    color var(--brand-accent)

// Prism 主题覆盖 — 深空蓝配色
pre[class*="language-"]
  background var(--code-bg)
  border 1px solid var(--border-subtle)
  border-radius $radius-md
  padding $space-lg
  margin 1.5em 0
  overflow-x auto

  code
    background none
    padding 0
    font-size $text-sm
    line-height 1.7

// 行号
.line-numbers .line-numbers-rows
  border-right 1px solid var(--border-subtle)

.line-numbers .line-numbers-rows > span::before
  color var(--code-line-number)

// Prism Token 配色 (深色模式)
:root[data-theme="dark"]
  .token.comment,
  .token.prolog,
  .token.doctype,
  .token.cdata
    color #5A6080

  .token.punctuation
    color #A8AECB

  .token.property,
  .token.tag,
  .token.boolean,
  .token.number,
  .token.constant,
  .token.symbol,
  .token.deleted
    color #FF6B9D

  .token.selector,
  .token.attr-name,
  .token.string,
  .token.char,
  .token.builtin,
  .token.inserted
    color #00E5FF

  .token.operator,
  .token.entity,
  .token.url
    color #A8AECB

  .token.atrule,
  .token.attr-value,
  .token.keyword
    color #7C5CFF

  .token.function,
  .token.class-name
    color #FFD166

  .token.regex,
  .token.important,
  .token.variable
    color #00E5FF

// Prism Token 配色 (浅色模式)
:root[data-theme="light"]
  .token.comment,
  .token.prolog,
  .token.doctype,
  .token.cdata
    color #8B92B0

  .token.punctuation
    color #4A5070

  .token.property,
  .token.tag,
  .token.boolean,
  .token.number,
  .token.constant,
  .token.symbol,
  .token.deleted
    color #E84F87

  .token.selector,
  .token.attr-name,
  .token.string,
  .token.char,
  .token.builtin,
  .token.inserted
    color #0099B8

  .token.atrule,
  .token.attr-value,
  .token.keyword
    color #6344FF

  .token.function,
  .token.class-name
    color #B8860B

  .token.regex,
  .token.important,
  .token.variable
    color #0099B8
