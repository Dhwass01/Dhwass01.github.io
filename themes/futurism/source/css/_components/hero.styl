// ============================================
//  Hero — 首页首屏
//  占位: Step 5 填充
// ============================================

.hero
  position relative
  display flex
  flex-direction column
  align-items center
  justify-content center
  min-height 100vh
  padding $space-3xl $space-lg
  text-align center
  overflow hidden

  // 渐变背景
  &::before
    content ''
    position absolute
    inset 0
    background radial-gradient(ellipse at 30% 20%, rgba(124,92,255,0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(0,229,255,0.10) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(255,107,157,0.05) 0%, transparent 60%)
    z-index 0
    animation hero-glow 12s ease-in-out infinite alternate

  @keyframes hero-glow
    0%
      opacity 0.7
      transform scale(1)
    50%
      opacity 1
      transform scale(1.05)
    100%
      opacity 0.7
      transform scale(1)

  .hero-content
    position relative
    z-index 1
    max-width 680px

  .hero-greeting
    font-family $font-mono
    font-size $text-sm
    color var(--brand-accent)
    letter-spacing 0.05em
    margin-bottom $space-md

  .hero-tagline
    font-family $font-display
    font-size $text-4xl
    font-weight 800
    line-height 1.15
    color var(--text-primary)
    margin-bottom $space-lg

    @media (max-width: $bp-mobile)
      font-size $text-2xl

  .hero-cta
    display flex
    gap $space-md
    justify-content center
    flex-wrap wrap
    margin-top $space-xl

    .btn
      display inline-flex
      align-items center
      gap $space-sm
      padding 0.65em 1.6em
      font-family $font-body
      font-size $text-sm
      font-weight 600
      border-radius $radius-md
      transition all $transition-base

    .btn-primary
      background var(--brand-primary)
      color #fff
      box-shadow 0 0 20px rgba(124,92,255,0.30)

      &:hover
        transform translateY(-2px)
        box-shadow 0 0 32px rgba(124,92,255,0.50)

    .btn-secondary
      border 1px solid var(--border-strong)
      color var(--text-primary)
      background transparent

      &:hover
        border-color var(--brand-accent)
        box-shadow var(--glow-accent)

  // 向下滚动提示
  .scroll-hint
    position absolute
    bottom $space-xl
    left 50%
    transform translateX(-50%)
    color var(--text-muted)
    font-size $text-xs
    animation bounce 2s ease infinite

  @keyframes bounce
    0%, 100%
      transform translateX(-50%) translateY(0)
    50%
      transform translateX(-50%) translateY(8px)
